rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 旧形式（1メモ1枚）の画像
    match /memos/{memoId}/image {
      allow read, write: if request.auth != null;
    }
    // 新形式（1メモ複数枚）の画像
    match /memos/{memoId}/images/{imageId} {
      allow read, write: if request.auth != null;
    }
  }
}
